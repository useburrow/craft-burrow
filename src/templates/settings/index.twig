{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = "Setup"|t('burrow') %}
{% set selectedNavItem = 'burrow' %}
{% set selectedSubnavItem = 'settings' %}
{% set fullPageForm = false %}
{% set crumbs = [
    { label: 'Burrow'|t('burrow'), url: cpUrl('burrow') },
] %}

{% set stepTitles = {
    connection: 'Establish connection',
    project: 'Choose client (Project)',
    integrations: 'Integrations',
    freeform: 'Freeform setup',
    formie: 'Formie setup',
    commerce: 'Craft Commerce setup',
    review: 'Review',
    finish: 'Finish'
} %}

{% block sidebar %}
    <nav>
        <ul>
            {% for wizardStep, wizardLabel in wizardSteps %}
                {% set isFutureStep = loop.index0 > currentStepIndex %}
                <li data-step="{{ wizardStep }}" class="{{ isFutureStep ? 'disabled' : '' }}">
                    {% if isFutureStep %}
                        <span class="disabled-link">
                            <span class="burrow-step-num">{{ loop.index }}.</span>{{ wizardLabel }}
                        </span>
                    {% else %}
                        <a href="{{ cpUrl('burrow/settings', { step: wizardStep }) }}" class="{{ wizardStep == step ? 'sel' : '' }}">
                            <span class="burrow-step-num">{{ loop.index }}.</span>{{ wizardLabel }}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endblock %}

{% block content %}
    <style>
        .burrow-step-num { color: #8f98a3; margin-right: 6px; }
        .burrow-card { padding: 20px; border: 1px solid #e3e5e8; border-radius: 6px; background: #fff; }
        .burrow-grid { display: grid; grid-template-columns: repeat(2, minmax(280px, 1fr)); gap: 16px; }
        .burrow-muted { color: #667085; }
        .burrow-form-list { max-height: 260px; overflow: auto; border: 1px solid #e3e5e8; border-radius: 4px; padding: 8px 12px; }
        .burrow-form-list label { display: block; margin: 6px 0; }
        #sidebar nav ul li.disabled .disabled-link { display: block; padding: 7px 14px; color: #a4acb6; cursor: not-allowed; }
        .burrow-freeform-form-block { margin: 0 0 24px 0; padding-top: 8px; border-top: 1px solid #e5e8ec; }
        .burrow-freeform-form-block:first-of-type { border-top: 0; padding-top: 0; }
        .burrow-freeform-form-block h3 { font-size: 18px; line-height: 1.3; margin: 0 0 10px 0; font-weight: 700; }
        .burrow-field-mapping-table-wrap { margin-top: 8px; }
        .burrow-field-mapping-table-wrap tr.is-disabled td { opacity: 0.5; }
        .burrow-review-table { margin-top: 8px; }
        .burrow-review-actions { margin-top: 10px; display: flex; align-items: center; gap: 10px; }
        .burrow-setup-icon { display: inline-flex; align-items: center; gap: 6px; margin-right: 10px; margin-bottom: 4px; }
        .burrow-setup-icon .burrow-icon-dot { width: 16px; height: 16px; border-radius: 50%; background: #0d66d0; color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; }
        .burrow-setup-icon .burrow-menu-glyph { width: 16px; height: 16px; object-fit: contain; }
        .burrow-project-table { margin-top: 10px; border: 1px solid #e3e5e8; border-radius: 6px; overflow: hidden; }
        .burrow-project-table thead th { background: #f7f8fa; font-weight: 700; padding: 10px 12px; }
        .burrow-project-table tbody td { padding: 11px 12px; vertical-align: middle; }
        .burrow-project-table tbody tr:nth-child(odd) td { background: #fff; }
        .burrow-project-table tbody tr:nth-child(even) td { background: #f9fafb; }
        .burrow-project-table tbody tr:hover td { background: #f2f7fd; }
        .burrow-project-table tbody tr { cursor: pointer; }
        .burrow-project-table td:first-child { width: 44px; text-align: center; }
        .burrow-project-table input[type="radio"] { width: 16px; height: 16px; accent-color: #0d66d0; }
        .burrow-project-name { font-weight: 600; }
        .burrow-project-id { display: block; margin-top: 2px; font-size: 11px; color: #667085; }
        .burrow-integration-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; margin-top: 12px; }
        .burrow-integration-card { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; transition: border-color .15s ease, box-shadow .15s ease, background .15s ease; }
        .burrow-integration-card:hover { border-color: #b8c2cf; box-shadow: 0 1px 2px rgba(16, 24, 40, 0.08); }
        .burrow-integration-card.is-selected { border-color: #0d66d0; background: #f4f8ff; box-shadow: 0 0 0 1px rgba(13, 102, 208, 0.15); }
        .burrow-integration-card.is-disabled { opacity: 0.6; background: #f7f8fa; }
        .burrow-integration-card-label { display: grid; grid-template-columns: 28px 1fr; gap: 10px; padding: 12px; cursor: pointer; }
        .burrow-integration-check { width: 16px; height: 16px; margin-top: 3px; accent-color: #0d66d0; }
        .burrow-integration-icon-wrap { width: 20px; height: 20px; border-radius: 4px; background: #eef2f6; display: inline-flex; align-items: center; justify-content: center; margin-right: 8px; vertical-align: middle; }
        .burrow-integration-icon-wrap img { width: 16px; height: 16px; object-fit: contain; }
        .burrow-integration-fallback { font-size: 11px; font-weight: 700; color: #475467; }
        .burrow-integration-title { font-weight: 700; color: #111927; }
        .burrow-integration-meta { margin-top: 3px; font-size: 12px; color: #667085; }
        .burrow-integration-description { margin-top: 6px; font-size: 12px; color: #4b5565; }
        .burrow-integration-status { display: inline-block; margin-top: 6px; font-size: 11px; color: #475467; background: #eef2f6; border-radius: 999px; padding: 2px 8px; }
        .burrow-commerce-panel { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; padding: 14px; margin-top: 10px; }
        .burrow-commerce-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .burrow-commerce-icon { width: 20px; height: 20px; object-fit: contain; }
        .burrow-commerce-mode-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 10px; margin-top: 10px; }
        .burrow-commerce-mode-card { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; }
        .burrow-commerce-mode-card label { display: block; padding: 12px; cursor: pointer; }
        .burrow-commerce-mode-card.is-selected { border-color: #0d66d0; background: #f4f8ff; }
        .burrow-commerce-mode-card .label { font-weight: 700; display: inline-block; margin-bottom: 2px; }
        .burrow-commerce-mode-card .hint { color: #667085; font-size: 12px; }
        .burrow-commerce-funnel { margin-top: 12px; padding: 10px 12px; border-radius: 6px; background: #f7f8fa; border: 1px solid #e3e5e8; }
        .burrow-commerce-funnel.is-disabled { opacity: 0.55; }
        .burrow-commerce-event-list { margin: 8px 0 0 18px; }
        .burrow-commerce-event-list li { margin: 2px 0; }
        .burrow-review-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin: 12px 0 6px; }
        .burrow-review-kpi { border: 1px solid #e3e5e8; border-radius: 8px; background: #fff; padding: 10px 12px; }
        .burrow-review-kpi .label { display: block; font-size: 12px; color: #667085; }
        .burrow-review-kpi .value { display: block; margin-top: 2px; font-size: 20px; font-weight: 700; color: #111927; }
        .burrow-review-panel { border: 1px solid #e3e5e8; border-radius: 8px; background: #fff; padding: 12px; margin-top: 12px; }
        .burrow-review-table { margin-top: 8px; }
        .burrow-status-chip { display: inline-flex; align-items: center; border-radius: 999px; padding: 2px 8px; font-size: 11px; font-weight: 600; border: 1px solid transparent; }
        .burrow-status-chip-ready { background: #ecfdf5; color: #047857; border-color: #86efac; }
        .burrow-status-chip-attention { background: #fff7ed; color: #9a3412; border-color: #fdba74; }
        .burrow-status-chip-off { background: #f3f4f6; color: #374151; border-color: #d1d5db; }
    </style>

    <div class="burrow-card">
        {% if not sdkAvailable %}
            <p class="warning with-icon">
                Burrow PHP SDK is not available. Install `useburrow/sdk-php` before onboarding.
            </p>
        {% endif %}

        <h2>{{ stepTitles[step] ?? 'Setup' }}</h2>

        {% if step == 'connection' %}
            <p class="burrow-muted">Connect this Craft site to Burrow and discover available projects.</p>

            <form method="post" action="{{ actionUrl('burrow/settings/save-connection') }}">
                {{ csrfInput() }}
                {{ forms.textField({
                    label: 'Base URL',
                    name: 'baseUrl',
                    value: settings.baseUrl,
                    required: true
                }) }}
                {{ forms.passwordField({
                    label: 'API Key',
                    name: 'apiKey',
                    value: settings.apiKey,
                    required: true
                }) }}
                <button class="btn submit">Connect & Discover</button>
            </form>

        {% elseif step == 'project' %}
            <p class="burrow-muted">Select the Burrow project this Craft site should sync with.</p>

            {% if projects is empty %}
                <p>No discovered projects yet. Run Step 1 first.</p>
            {% else %}
                {% set selectedProjectId = state.projectId ?? '' %}
                {% set hasSelectedProject = false %}
                {% for project in projects %}
                    {% if (project.projectId ?? '') == selectedProjectId %}
                        {% set hasSelectedProject = true %}
                    {% endif %}
                {% endfor %}
                <form method="post" action="{{ actionUrl('burrow/settings/select-project') }}">
                    {{ csrfInput() }}
                    <table class="data fullwidth burrow-project-table">
                        <thead>
                            <tr>
                                <th></th>
                                <th>Project</th>
                                <th>Client</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for project in projects %}
                                {% set projectId = project.projectId ?? '' %}
                                {% set isChecked = projectId == selectedProjectId or (not hasSelectedProject and loop.first) %}
                                <tr class="burrow-project-row">
                                    <td><input type="radio" name="projectSelection" value="{{ project|json_encode|e('html_attr') }}" {{ isChecked ? 'checked' : '' }} required></td>
                                    <td>
                                        <span class="burrow-project-name">{{ project.projectName ?: project.projectId }}</span>
                                        <span class="burrow-project-id">{{ project.projectId }}</span>
                                    </td>
                                    <td>{{ project.clientName ?: project.clientId }}</td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                    <div style="margin-top: 15px;">
                        <button class="btn submit">Link Project</button>
                    </div>
                </form>
                <script>
                    (() => {
                        const rows = Array.from(document.querySelectorAll('.burrow-project-row'));
                        if (!rows.length) {
                            return;
                        }
                        rows.forEach((row) => {
                            row.addEventListener('click', (event) => {
                                const target = event.target;
                                if (!(target instanceof HTMLElement)) {
                                    return;
                                }
                                if (target.closest('input[type="radio"]')) {
                                    return;
                                }
                                const radio = row.querySelector('input[type="radio"][name="projectSelection"]');
                                if (!radio) {
                                    return;
                                }
                                radio.checked = true;
                                radio.dispatchEvent(new Event('change', { bubbles: true }));
                            });
                        });
                    })();
                </script>
            {% endif %}

        {% elseif step == 'integrations' %}
            <p class="burrow-muted">Select integration providers to bridge into Burrow.</p>
            {% set integrationDescriptions = {
                freeform: 'Capture Freeform submissions and sync contracts to Burrow.',
                formie: 'Capture Formie submissions with count-only or custom-field mappings.',
                commerce: 'Sync Commerce order and item lifecycle events to Burrow.'
            } %}

            <form method="post" action="{{ actionUrl('burrow/settings/save-integrations') }}">
                {{ csrfInput() }}
                {% if availableIntegrations is empty %}
                    <p class="burrow-muted">No supported integrations are currently installed.</p>
                {% else %}
                    <div class="burrow-integration-grid">
                    {% for key, integration in availableIntegrations %}
                        {% set isInstalled = integration.installed %}
                        {% set isChecked = key in state.selectedIntegrations %}
                        <div class="burrow-integration-card {{ isChecked ? 'is-selected' : '' }} {{ not isInstalled ? 'is-disabled' : '' }}">
                            <label class="burrow-integration-card-label">
                                <input
                                    class="burrow-integration-checkbox burrow-integration-check"
                                    type="checkbox"
                                    name="integrations[]"
                                    value="{{ key }}"
                                    {{ isChecked ? 'checked' : '' }}
                                    {{ not isInstalled ? 'disabled' : '' }}
                                >
                                <span>
                                    <span class="burrow-integration-icon-wrap" aria-hidden="true">
                                        {% if integration.iconDataUri %}
                                            <img src="{{ integration.iconDataUri }}" alt="">
                                        {% else %}
                                            <span class="burrow-integration-fallback">{{ (integration.label|slice(0, 1))|upper }}</span>
                                        {% endif %}
                                    </span>
                                    <span class="burrow-integration-title">{{ integration.label }}</span>
                                    <div class="burrow-integration-meta">Version: {{ integration.version ?: '-' }}</div>
                                    <div class="burrow-integration-description">{{ integrationDescriptions[key] ?? 'Bridge this provider into Burrow event and contract flows.' }}</div>
                                    <span class="burrow-integration-status">{{ isInstalled ? 'Installed' : 'Not installed' }}</span>
                                </span>
                            </label>
                        </div>
                    {% endfor %}
                    </div>
                {% endif %}
                <div style="margin-top: 15px;">
                    <button id="burrow-save-integrations" class="btn submit" {{ availableIntegrations is empty ? 'disabled' : '' }}>Save Integrations</button>
                </div>
            </form>
            <script>
                (() => {
                    const boxes = Array.from(document.querySelectorAll('.burrow-integration-checkbox'));
                    const submit = document.getElementById('burrow-save-integrations');
                    if (!boxes.length || !submit) {
                        return;
                    }
                    const syncCards = () => {
                        boxes.forEach((box) => {
                            const card = box.closest('.burrow-integration-card');
                            if (!card) {
                                return;
                            }
                            card.classList.toggle('is-selected', box.checked);
                        });
                    };
                    const sync = () => {
                        submit.disabled = boxes.filter((box) => box.checked).length === 0;
                        syncCards();
                    };
                    boxes.forEach((box) => box.addEventListener('change', sync));
                    sync();
                })();
            </script>

        {% elseif step == 'freeform' %}
            {% set freeformConfig = integrationStepData.settings.freeform ?? {} %}
            {% set freeformSavedForms = freeformConfig.forms ?? {} %}
            <p class="burrow-muted">
                Target guide: properties are event details (context), while tags are report-friendly dimensions used for filtering, grouping, or charting.
            </p>
            <p class="burrow-muted">
                Tip: use Count-only tracking to send minimal events with formId, formName, submissionId, and timestamp even when no additional fields are selected.
            </p>
            <form method="post" action="{{ actionUrl('burrow/settings/save-integration-step') }}">
                {{ csrfInput() }}
                <input type="hidden" name="integration" value="freeform">
                {{ forms.textField({
                    label: 'Provider prefix',
                    instructions: 'Short prefix prepended to form IDs in events (e.g. FF1). Prevents ID collisions across form plugins.',
                    id: 'freeformPrefix',
                    name: 'freeformPrefix',
                    value: freeformConfig.prefix ?? 'FF',
                    size: 6,
                    maxlength: 10,
                }) }}
                {% if integrationStepData.freeformForms is empty %}
                    <p class="burrow-muted">No Freeform forms were found.</p>
                {% else %}
                    {% for form in integrationStepData.freeformForms %}
                        {% set formConfig = freeformSavedForms[form.id] ?? {} %}
                        {% set formMode = formConfig.mode ?? 'off' %}
                        {% set isCustomMode = formMode == 'custom_fields' %}
                        {% set formFields = integrationStepData.freeformFieldsByFormId[form.id] ?? [] %}
                        {% set mappedFields = formConfig.fields ?? {} %}
                        <div class="burrow-freeform-form-block" data-form-id="{{ form.id }}">
                            <h3>{{ form.name }}</h3>
                            <fieldset style="margin:0 0 10px 0;">
                                <legend><strong>Tracking mode</strong></legend>
                                <span style="margin-right:14px;">{{ forms.radio({
                                    class: 'burrow-form-mode-radio',
                                    name: 'freeform[forms][' ~ form.id ~ '][mode]',
                                    value: 'off',
                                    checked: formMode == 'off',
                                    label: 'Off'
                                }) }}</span>
                                <span style="margin-right:14px;">{{ forms.radio({
                                    class: 'burrow-form-mode-radio',
                                    name: 'freeform[forms][' ~ form.id ~ '][mode]',
                                    value: 'count_only',
                                    checked: formMode == 'count_only',
                                    label: 'Count-only'
                                }) }}</span>
                                <span>{{ forms.radio({
                                    class: 'burrow-form-mode-radio',
                                    name: 'freeform[forms][' ~ form.id ~ '][mode]',
                                    value: 'custom_fields',
                                    checked: formMode == 'custom_fields',
                                    label: 'Custom fields'
                                }) }}</span>
                            </fieldset>
                            <input type="hidden" name="freeform[forms][{{ form.id }}][externalFormId]" value="{{ form.id }}">
                            <input type="hidden" name="freeform[forms][{{ form.id }}][formName]" value="{{ form.name }}">
                            {% if formFields is empty %}
                                <p class="burrow-muted">No fields detected for this form.</p>
                            {% else %}
                                <div class="burrow-field-mapping-table-wrap">
                                    <table class="data fullwidth">
                                        <thead>
                                            <tr>
                                                <th>Include</th>
                                                <th>Field</th>
                                                <th>Type</th>
                                                <th>Canonical Key</th>
                                                <th>Target</th>
                                                <th>Display Label</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            {% for field in formFields %}
                                                {% set fieldConfig = mappedFields[field.externalFieldId] ?? {} %}
                                                {% set isIncluded = fieldConfig ? true : false %}
                                                {% set canonicalKey = fieldConfig.canonicalKey ?? field.canonicalKey %}
                                                {% set target = fieldConfig.target ?? '' %}
                                                {% set displayLabel = fieldConfig.displayLabelOverride ?? field.sourceLabel %}
                                                <tr class="{{ isCustomMode ? '' : 'is-disabled' }}">
                                                    <td>
                                                        {{ forms.checkbox({
                                                            id: 'freeform-' ~ form.id ~ '-field-' ~ field.externalFieldId ~ '-include',
                                                            class: 'burrow-form-field-checkbox',
                                                            name: 'freeform[forms][' ~ form.id ~ '][fields][' ~ field.externalFieldId ~ '][include]',
                                                            value: 1,
                                                            checked: isIncluded,
                                                            disabled: (not isCustomMode),
                                                            label: ' '
                                                        }) }}
                                                    </td>
                                                    <td>{{ field.sourceLabel }}</td>
                                                    <td>{{ field.dataType }}</td>
                                                    <td>
                                                        <div class="input ltr">
                                                            <input class="text fullwidth" type="text" name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][canonicalKey]" value="{{ canonicalKey }}" {{ not isCustomMode ? 'disabled' : '' }}>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="select">
                                                            <select name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][target]" {{ not isCustomMode ? 'disabled' : '' }}>
                                                                <option value="">Select one</option>
                                                                <option value="properties" {{ target == 'properties' ? 'selected' : '' }}>properties</option>
                                                                <option value="tags" {{ target == 'tags' ? 'selected' : '' }}>tags</option>
                                                            </select>
                                                        </div>
                                                    </td>
                                                    <td>
                                                        <div class="input ltr">
                                                            <input class="text fullwidth" type="text" name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][displayLabelOverride]" value="{{ displayLabel }}" {{ not isCustomMode ? 'disabled' : '' }}>
                                                        </div>
                                                    </td>
                                                </tr>
                                                <input type="hidden" name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][externalFieldId]" value="{{ field.externalFieldId }}" {{ not isCustomMode ? 'disabled' : '' }}>
                                                <input type="hidden" name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][sourceLabel]" value="{{ field.sourceLabel }}" {{ not isCustomMode ? 'disabled' : '' }}>
                                                <input type="hidden" name="freeform[forms][{{ form.id }}][fields][{{ field.externalFieldId }}][dataType]" value="{{ field.dataType }}" {{ not isCustomMode ? 'disabled' : '' }}>
                                            {% endfor %}
                                        </tbody>
                                    </table>
                                </div>
                            {% endif %}
                        </div>
                    {% endfor %}
                    <script>
                        (() => {
                            const forms = Array.from(document.querySelectorAll('.burrow-freeform-form-block'));
                            if (!forms.length) return;
                            const parentForm = forms[0].closest('form');
                            forms.forEach((block) => {
                                const modeInputs = Array.from(block.querySelectorAll('.burrow-form-mode-radio'));
                                const fields = Array.from(block.querySelectorAll('.burrow-form-field-checkbox'));
                                if (!modeInputs.length) return;
                                const controls = Array.from(block.querySelectorAll('.burrow-field-mapping-table-wrap input, .burrow-field-mapping-table-wrap select, .burrow-field-mapping-table-wrap textarea'));
                                const currentMode = () => {
                                    const picked = modeInputs.find((input) => input.checked);
                                    return picked ? picked.value : 'off';
                                };
                                const sync = () => {
                                    const mode = currentMode();
                                    const fieldsEnabled = mode === 'custom_fields';
                                    if (!fieldsEnabled) {
                                        fields.forEach((field) => { field.checked = false; });
                                    }
                                    const rows = Array.from(block.querySelectorAll('.burrow-field-mapping-table-wrap tbody tr'));
                                    rows.forEach((row) => row.classList.toggle('is-disabled', !fieldsEnabled));
                                    controls.forEach((control) => {
                                        if (!fieldsEnabled) {
                                            control.setAttribute('disabled', 'disabled');
                                        } else {
                                            control.removeAttribute('disabled');
                                        }
                                    });
                                    block.classList.toggle('burrow-count-only-active', mode === 'count_only');
                                };
                                modeInputs.forEach((input) => input.addEventListener('change', sync));
                                fields.forEach((field) => field.addEventListener('change', sync));
                                sync();
                            });
                            if (!parentForm) return;
                            parentForm.addEventListener('submit', (event) => {
                                for (const block of forms) {
                                    const selectedMode = block.querySelector('.burrow-form-mode-radio:checked');
                                    const mode = selectedMode ? selectedMode.value : 'off';
                                    if (mode !== 'custom_fields') {
                                        continue;
                                    }
                                    const heading = block.querySelector('h3');
                                    const formName = heading && heading.textContent ? heading.textContent.trim() : 'This form';
                                    const includedFields = Array.from(block.querySelectorAll('.burrow-form-field-checkbox:checked'));
                                    if (!includedFields.length) {
                                        event.preventDefault();
                                        window.alert(formName + ': please include at least one field when using Custom fields mode.');
                                        return;
                                    }
                                    for (const checkbox of includedFields) {
                                        const row = checkbox.closest('tr');
                                        const targetSelect = row ? row.querySelector('select[name*="[target]"]') : null;
                                        if (targetSelect && !targetSelect.value) {
                                            event.preventDefault();
                                            window.alert(formName + ': please choose a target for each included field.');
                                            targetSelect.focus();
                                            return;
                                        }
                                    }
                                }
                            });
                        })();
                    </script>
                {% endif %}
                <div style="margin-top: 16px;">
                    <button class="btn submit">Continue to {{ stepTitles[nextStep] ?? (wizardSteps[nextStep] ?? 'next step') }}</button>
                </div>
            </form>

        {% elseif step == 'formie' %}
            {% set formieConfig = integrationStepData.settings.formie ?? {} %}
            <p class="burrow-muted">Select Formie forms and tracking mode for Burrow contracts.</p>
            <form method="post" action="{{ actionUrl('burrow/settings/save-integration-step') }}">
                {{ csrfInput() }}
                <input type="hidden" name="integration" value="formie">
                {{ forms.textField({
                    label: 'Provider prefix',
                    instructions: 'Short prefix prepended to form IDs in events (e.g. FRM1). Prevents ID collisions across form plugins.',
                    id: 'formiePrefix',
                    name: 'formiePrefix',
                    value: formieConfig.prefix ?? 'FRM',
                    size: 6,
                    maxlength: 10,
                }) }}
                <fieldset>
                    <legend><strong>Tracking mode</strong></legend>
                    {{ forms.radio({
                        name: 'formieMode',
                        value: 'off',
                        checked: (formieConfig.mode ?? 'count_only') == 'off',
                        label: 'Off'
                    }) }}<br>
                    {{ forms.radio({
                        name: 'formieMode',
                        value: 'count_only',
                        checked: (formieConfig.mode ?? 'count_only') == 'count_only',
                        label: 'Count-only'
                    }) }}
                </fieldset>
                <div style="margin-top: 14px;">
                    <strong>Forms</strong>
                    {% if integrationStepData.formieForms is empty %}
                        <p class="burrow-muted">No Formie forms were found.</p>
                    {% else %}
                        <div class="burrow-form-list">
                            {% for form in integrationStepData.formieForms %}
                                <label>
                                    <input type="checkbox" name="formieFormIds[]" value="{{ form.id }}" {{ form.id in (formieConfig.formIds ?? []) ? 'checked' : '' }}>
                                    {{ form.name }} <span class="burrow-muted">({{ form.handle ?: form.id }})</span>
                                </label>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>
                <div style="margin-top: 16px;">
                    <button class="btn submit">Continue to {{ stepTitles[nextStep] ?? (wizardSteps[nextStep] ?? 'next step') }}</button>
                </div>
            </form>

        {% elseif step == 'commerce' %}
            {% set commerceConfig = integrationStepData.settings.commerce ?? {} %}
            {% set commerceIcon = availableIntegrations.commerce.iconDataUri ?? '' %}
            <p class="burrow-muted">Configure how Craft Commerce order lifecycle and funnel activity should be sent to Burrow.</p>
            <form method="post" action="{{ actionUrl('burrow/settings/save-integration-step') }}">
                {{ csrfInput() }}
                <input type="hidden" name="integration" value="commerce">
                <div class="burrow-commerce-panel">
                    <div class="burrow-commerce-header">
                        {% if commerceIcon %}
                            <img class="burrow-commerce-icon" src="{{ commerceIcon }}" alt="" aria-hidden="true">
                        {% else %}
                            <span class="burrow-integration-icon-wrap"><span class="burrow-integration-fallback">C</span></span>
                        {% endif %}
                        <strong>Craft Commerce</strong>
                    </div>
                    <p class="burrow-muted">Core events include order placed and item purchased. Funnel events are optional.</p>

                    {% set commerceMode = commerceConfig.mode ?? 'track' %}
                    <div class="burrow-commerce-mode-grid">
                        <div class="burrow-commerce-mode-card {{ commerceMode == 'track' ? 'is-selected' : '' }}">
                            <label>
                                {{ forms.radio({
                                    class: 'burrow-commerce-mode-radio',
                                    name: 'commerceMode',
                                    value: 'track',
                                    checked: commerceMode == 'track',
                                    label: 'Track events'
                                }) }}
                                <span class="hint">Enable Commerce event publishing to Burrow.</span>
                            </label>
                        </div>
                        <div class="burrow-commerce-mode-card {{ commerceMode == 'off' ? 'is-selected' : '' }}">
                            <label>
                                {{ forms.radio({
                                    class: 'burrow-commerce-mode-radio',
                                    name: 'commerceMode',
                                    value: 'off',
                                    checked: commerceMode == 'off',
                                    label: 'Turn off tracking'
                                }) }}
                                <span class="hint">Pause Commerce event publishing for this site.</span>
                            </label>
                        </div>
                    </div>

                    <div class="burrow-commerce-funnel {{ commerceMode == 'off' ? 'is-disabled' : '' }}">
                        <label>
                            <input class="burrow-commerce-funnel-checkbox" type="checkbox" name="ecommerceFunnel" value="1" {{ (commerceConfig.ecommerceFunnel ?? false) ? 'checked' : '' }} {{ commerceMode == 'off' ? 'disabled' : '' }}>
                            Enable cart & checkout funnel events
                        </label>
                        <ul class="burrow-commerce-event-list burrow-muted">
                            <li><code>ecommerce.cart.added</code></li>
                            <li><code>ecommerce.checkout.started</code></li>
                            <li><code>ecommerce.checkout.abandoned</code></li>
                            <li><code>ecommerce.cart.recovered</code></li>
                        </ul>
                    </div>
                </div>
                <div style="margin-top: 16px;">
                    <button class="btn submit">Continue to {{ stepTitles[nextStep] ?? (wizardSteps[nextStep] ?? 'next step') }}</button>
                </div>
            </form>
            <script>
                (() => {
                    const modeInputs = Array.from(document.querySelectorAll('.burrow-commerce-mode-radio'));
                    const funnelWrap = document.querySelector('.burrow-commerce-funnel');
                    const funnelBox = document.querySelector('.burrow-commerce-funnel-checkbox');
                    const modeCards = Array.from(document.querySelectorAll('.burrow-commerce-mode-card'));
                    if (!modeInputs.length || !funnelWrap || !funnelBox) {
                        return;
                    }
                    const currentMode = () => {
                        const checked = modeInputs.find((input) => input.checked);
                        return checked ? checked.value : 'track';
                    };
                    const sync = () => {
                        const mode = currentMode();
                        modeCards.forEach((card) => {
                            const input = card.querySelector('.burrow-commerce-mode-radio');
                            card.classList.toggle('is-selected', !!input && input.checked);
                        });
                        const enabled = mode !== 'off';
                        funnelWrap.classList.toggle('is-disabled', !enabled);
                        if (!enabled) {
                            funnelBox.checked = false;
                            funnelBox.setAttribute('disabled', 'disabled');
                        } else {
                            funnelBox.removeAttribute('disabled');
                        }
                    };
                    modeInputs.forEach((input) => input.addEventListener('change', sync));
                    sync();
                })();
            </script>

        {% elseif step == 'review' %}
            {% set contractCount = contractRows|length %}
            {% set integrationCount = integrationReadinessRows|length %}
            {% set readinessReadyCount = 0 %}
            {% set mappedFieldTotal = 0 %}
            {% for row in integrationReadinessRows %}
                {% set normalizedStatus = (row.status ?? '')|lower %}
                {% if 'ready' in normalizedStatus %}
                    {% set readinessReadyCount = readinessReadyCount + 1 %}
                {% endif %}
            {% endfor %}
            {% for row in contractRows %}
                {% set mappedFieldTotal = mappedFieldTotal + (row.mappingCount ?? 0) %}
            {% endfor %}
            <p>Review exactly what will be sent to Burrow when contracts are synced.</p>
            <div class="burrow-review-summary">
                <div class="burrow-review-kpi">
                    <span class="label">Integrations</span>
                    <span class="value">{{ integrationCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Ready</span>
                    <span class="value">{{ readinessReadyCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Contracts to sync</span>
                    <span class="value">{{ contractCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Mapped fields</span>
                    <span class="value">{{ mappedFieldTotal }}</span>
                </div>
            </div>

            <div class="burrow-review-panel">
                <h3>Integration Readiness</h3>
                <table class="data fullwidth burrow-review-table">
                    <thead>
                    <tr>
                        <th>Integration</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if integrationReadinessRows is empty %}
                        <tr><td colspan="2">No integrations selected.</td></tr>
                    {% else %}
                        {% for row in integrationReadinessRows %}
                            {% set normalizedStatus = (row.status ?? '')|lower %}
                            {% set chipClass = 'burrow-status-chip-attention' %}
                            {% if 'ready' in normalizedStatus %}
                                {% set chipClass = 'burrow-status-chip-ready' %}
                            {% elseif 'off' in normalizedStatus %}
                                {% set chipClass = 'burrow-status-chip-off' %}
                            {% endif %}
                            <tr>
                                <td>{{ row.name }}</td>
                                <td><span class="burrow-status-chip {{ chipClass }}">{{ row.status }}</span></td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="burrow-review-panel">
                <h3>Contracts To Sync</h3>
                <table class="data fullwidth burrow-review-table">
                    <thead>
                    <tr>
                        <th>Provider</th>
                        <th>Form</th>
                        <th>Form ID</th>
                        <th>Mode</th>
                        <th>Mapped fields</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if contractRows is empty %}
                        <tr><td colspan="5">No enabled contracts yet. Return to provider setup and enable at least one form.</td></tr>
                    {% else %}
                        {% for row in contractRows %}
                            <tr>
                                <td>{{ row.provider }}</td>
                                <td>{{ row.formName ?: '-' }}</td>
                                <td><code>{{ row.externalFormId ?: '-' }}</code></td>
                                <td>{{ row.mode }}</td>
                                <td>{{ row.mappingCount }}</td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="burrow-review-actions">
                <form method="post" action="{{ actionUrl('burrow/settings/sync-contracts') }}">
                    {{ csrfInput() }}
                    <button class="btn submit" {{ contractRows is empty ? 'disabled' : '' }}>Sync Contracts to Burrow</button>
                </form>
                {% if contractSyncMeta.syncedAt is defined and contractSyncMeta.syncedAt %}
                    <span class="burrow-muted">
                        Last sync: {{ contractSyncMeta.syncedAt }}
                        {% if contractSyncMeta.version is defined and contractSyncMeta.version %}
                            (version: {{ contractSyncMeta.version }})
                        {% endif %}
                    </span>
                {% endif %}
            </div>

        {% elseif step == 'finish' %}
            <table class="data fullwidth" style="max-width:960px;">
                <tbody>
                <tr>
                    <th>Connected Project</th>
                    <td>
                        <code>{{ state.projectId ?: '-' }}</code>
                        {% if projectUrl %}
                            &nbsp;<a href="{{ projectUrl }}" target="_blank" rel="noopener noreferrer">View in Burrow &#8594;</a>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Base URL</th>
                    <td><code>{{ settings.baseUrl }}</code></td>
                </tr>
                <tr>
                    <th>Integrations</th>
                    <td>
                        {% if integrationSummaryRows is empty %}
                            <span class="burrow-muted">None selected</span>
                        {% else %}
                            {% for row in integrationSummaryRows %}
                                <span class="burrow-setup-icon">
                                    {% if row.iconDataUri %}
                                        <img class="burrow-menu-glyph" src="{{ row.iconDataUri }}" alt="" aria-hidden="true">
                                    {% else %}
                                        <span class="burrow-icon-dot">{{ (row.label|slice(0, 1))|upper }}</span>
                                    {% endif %}
                                    <strong>{{ row.label }}</strong>
                                    {% if row.detail %}
                                        <span class="burrow-muted">{{ row.detail }}</span>
                                    {% endif %}
                                </span>
                            {% endfor %}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Contracts Synced</th>
                    <td>{{ contractSyncMeta.syncedAt ?? 'Not yet synced' }}</td>
                </tr>
                </tbody>
            </table>

            <h2 style="margin-top:24px;">Active Contracts</h2>
            <table class="data fullwidth" style="max-width:900px;">
                <thead>
                <tr>
                    <th>Provider</th>
                    <th>Form</th>
                    <th>Form ID</th>
                    <th>Mode</th>
                    <th>Mapped Fields</th>
                </tr>
                </thead>
                <tbody>
                {% if contractRows is empty %}
                    <tr><td colspan="5">No active contracts.</td></tr>
                {% else %}
                    {% for row in contractRows %}
                        <tr>
                            <td>{{ row.provider }}</td>
                            <td>{{ row.formName ?: '-' }}</td>
                            <td>{{ row.externalFormId ?: '-' }}</td>
                            <td>{{ row.mode }}</td>
                            <td>{{ row.mappingCount }}</td>
                        </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>

            <h2 style="margin-top:24px;">Craft Commerce</h2>
            {% set commerceConfig = state.integrationSettings.commerce ?? {} %}
            {% if 'commerce' in state.selectedIntegrations and (commerceConfig.mode ?? 'track') == 'track' %}
                <p>Tracking <code>ecommerce.order.placed</code> and <code>ecommerce.item.purchased</code> events for all Craft Commerce orders.</p>
            {% else %}
                <p class="burrow-muted">Commerce tracking is currently off.</p>
            {% endif %}

            <h2 style="margin-top:24px;">Data Backfill</h2>
            {% set backfillMeta = state.integrationSettings.backfill ?? {} %}
            {% set backfillStatus = backfillMeta.status ?? '' %}
            <p class="burrow-muted">
                {% if backfillStatus == 'completed' %}
                    Last backfill completed: {{ backfillMeta.accepted ?? 0 }} accepted, {{ backfillMeta.rejected ?? 0 }} rejected.
                {% elseif backfillStatus == 'failed' %}
                    Last backfill failed. Open Dashboard to review and retry.
                {% elseif backfillStatus == 'running' %}
                    A backfill is running in the queue. Open Dashboard for live counts.
                {% elseif backfillStatus == 'queued' %}
                    A backfill is queued; ensure the queue worker is running.
                {% else %}
                    Next step: run your first backfill in Dashboard to import historical forms and Craft Commerce orders.
                {% endif %}
            </p>
            <p>
                <a class="btn" href="{{ cpUrl('burrow/dashboard') }}#data-backfill">Run Backfill in Dashboard</a>
            </p>
            <p style="margin-top:20px;">
                <a class="btn submit" href="{{ cpUrl('burrow/dashboard') }}">Go to Dashboard</a>
                <a class="btn" href="{{ cpUrl('burrow/settings', { step: 'connection' }) }}" style="margin-left:6px;">Reconfigure</a>
            </p>

        {% else %}
            <p>Burrow bridge is configured.</p>
            <p><strong>Linked project:</strong> {{ state.projectId ?: 'N/A' }}</p>
            <p><strong>Selected integrations:</strong> {{ state.selectedIntegrations|join(', ') ?: 'N/A' }}</p>
            <p><a class="btn" href="{{ cpUrl('burrow/settings', { step: 'review' }) }}">Back to Review</a></p>
        {% endif %}
    </div>
{% endblock %}
