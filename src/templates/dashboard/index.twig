{% extends "_layouts/cp" %}

{% set title = "Dashboard"|t('burrow') %}
{% set selectedNavItem = 'burrow' %}
{% set selectedSubnavItem = selectedSubnavItem ?? 'dashboard' %}
{% set crumbs = [
    { label: 'Burrow'|t('burrow'), url: cpUrl('burrow') },
] %}

{% block content %}
    <style>
        .burrow-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; margin: 16px 0 24px; }
        .burrow-card { border: 1px solid #e3e5e8; border-radius: 8px; padding: 14px 16px; background: #fff; }
        .burrow-card-label { color: #667085; font-size: 13px; }
        .burrow-card-value { font-size: 28px; line-height: 1.1; font-weight: 700; margin-top: 6px; letter-spacing: -0.02em; }
        .burrow-card-detail { color: #667085; font-size: 13px; margin-top: 4px; }
        .burrow-status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 3px 10px;
            border-radius: 999px;
            font-size: 12px;
            font-weight: 600;
            line-height: 1.5;
            border: 1px solid transparent;
        }
        .burrow-status-completed { background: #ecfdf5; color: #047857; border-color: #86efac; }
        .burrow-status-failed { background: #fef2f2; color: #b91c1c; border-color: #fca5a5; }
        .burrow-status-running { background: #eff6ff; color: #1d4ed8; border-color: #93c5fd; }
        .burrow-status-queued { background: #f5f3ff; color: #5b21b6; border-color: #c4b5fd; }
        .burrow-status-idle { background: #f3f4f6; color: #374151; border-color: #d1d5db; }
        .burrow-section { margin-top: 28px; }
    </style>

    {% set backfillStatus = backfillState.status ?? 'idle' %}
    {% set outboxPendingTotal = queueStats.pending + queueStats.retrying %}
    {% set projectName = state.burrowProject.name ?? '' %}

    <div class="burrow-grid">
        <div class="burrow-card">
            <div class="burrow-card-label">Project</div>
            {% if projectName %}
                <div class="burrow-card-value" style="font-size: 20px;">{{ projectName }}</div>
            {% elseif state.projectId %}
                <div class="burrow-card-value" style="font-size: 14px; font-family: monospace;">{{ state.projectId }}</div>
            {% else %}
                <div class="burrow-card-value">&mdash;</div>
                <div class="burrow-card-detail">Not linked</div>
            {% endif %}
            {% if projectUrl %}
                <div class="burrow-card-detail"><a href="{{ projectUrl }}" target="_blank" rel="noopener noreferrer">View in Burrow &#8594;</a></div>
            {% endif %}
        </div>

        <div class="burrow-card">
            <div class="burrow-card-label">Integrations</div>
            <div class="burrow-card-value">{{ integrationNames|length }}</div>
            <div class="burrow-card-detail">{{ integrationNames|join(', ') ?: 'None selected' }}</div>
        </div>

        <div class="burrow-card">
            <div class="burrow-card-label">Outbox</div>
            <div class="burrow-card-value">{{ outboxPendingTotal }}</div>
            <div class="burrow-card-detail">
                {% if queueStats.failed > 0 %}
                    <span style="color: #b91c1c;">{{ queueStats.failed }} failed</span> &middot;
                {% endif %}
                {{ queueStats.sent }} sent
            </div>
        </div>
    </div>

    <div style="margin-bottom: 28px;">
        <a class="btn" href="{{ cpUrl('burrow/settings') }}">Settings</a>
        <a class="btn" href="{{ cpUrl('burrow/outbox') }}">View Outbox</a>
    </div>

    <h2>Form Contracts</h2>
    <table class="data fullwidth">
        <thead>
        <tr>
            <th>Provider</th>
            <th>Form</th>
            <th>Form ID</th>
            <th>Mode</th>
            <th>Fields</th>
        </tr>
        </thead>
        <tbody>
        {% if contractRows is empty %}
            <tr><td colspan="5">No active contracts.</td></tr>
        {% else %}
            {% for row in contractRows %}
                <tr>
                    <td>{{ row.provider }}</td>
                    <td>{{ row.formName ?: '-' }}</td>
                    <td>{{ row.externalFormId ?: '-' }}</td>
                    <td>{{ row.mode }}</td>
                    <td>{{ row.mappingCount }}</td>
                </tr>
            {% endfor %}
        {% endif %}
        </tbody>
    </table>

    <div class="burrow-section">
        <h2 id="data-backfill">Data Backfill</h2>
        <p>
            {% if backfillStatus == 'completed' %}
                <span class="burrow-status-badge burrow-status-completed">Completed</span>
            {% elseif backfillStatus == 'failed' %}
                <span class="burrow-status-badge burrow-status-failed">Failed</span>
            {% elseif backfillStatus == 'running' %}
                <span class="burrow-status-badge burrow-status-running">Running</span>
            {% elseif backfillStatus == 'queued' %}
                <span class="burrow-status-badge burrow-status-queued">Queued</span>
            {% else %}
                <span class="burrow-status-badge burrow-status-idle">Idle</span>
            {% endif %}
            {% if backfillState is not empty %}
                <span class="burrow-card-detail" style="margin-left: 8px;">
                    {{ backfillState.accepted ?? 0 }} accepted, {{ backfillState.rejected ?? 0 }} rejected
                </span>
            {% endif %}
        </p>
        {% if backfillStatus == 'queued' or backfillStatus == 'running' %}
            <p class="burrow-card-detail" style="margin: 10px 0; max-width: 720px;">
                {{ 'If the queue worker stopped or a job timed out, the dashboard can still show this status while nothing is running. Use reset, then start again.'|t('burrow') }}
                <form method="post" action="{{ actionUrl('burrow/settings/reset-backfill') }}" style="display: inline-block; margin-left: 8px;">
                    {{ csrfInput() }}
                    <button type="submit" class="btn">{{ 'Reset stuck backfill'|t('burrow') }}</button>
                </form>
            </p>
        {% endif %}
        <form method="post" action="{{ actionUrl('burrow/settings/start-backfill') }}">
            {{ csrfInput() }}
            <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                <div class="select">
                    <select name="backfillWindowPreset">
                        {% for preset, label in backfillPresets %}
                            <option value="{{ preset }}" {{ preset == (backfillState.windowPreset ?? 'last_30_days') ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <span>Sources:</span>
                {% if availableBackfillSources is empty %}
                    <span class="burrow-card-detail">No eligible integrations configured.</span>
                {% else %}
                    {% for source in availableBackfillSources %}
                        <label>
                            <input type="checkbox" name="backfillSources[]" value="{{ source }}" {{ source in backfillSources ? 'checked' : '' }}>
                            {{ source == 'ecommerce' ? 'Craft Commerce' : 'Forms' }}
                        </label>
                    {% endfor %}
                {% endif %}
                <button class="btn submit" {{ (availableBackfillSources is empty or backfillStatus == 'queued' or backfillStatus == 'running') ? 'disabled' : '' }}>Start Backfill</button>
                <a class="btn" href="{{ cpUrl('burrow/backfill-probe', { windowPreset: backfillState.windowPreset ?? 'last_90_days' }) }}">Backfill Probe</a>
            </div>
        </form>
        {% if backfillState is not empty and (backfillState.completedAt ?? backfillState.startedAt ?? '') %}
            <p class="burrow-card-detail" style="margin-top: 8px;">
                Last run: {{ backfillState.completedAt ?? backfillState.startedAt }} &middot;
                {{ backfillState.requested ?? 0 }} requested,
                {{ backfillState.accepted ?? 0 }} accepted,
                {{ backfillState.rejected ?? 0 }} rejected
                {% if (backfillState.validationRejected ?? 0) > 0 %}, {{ backfillState.validationRejected }} validation rejected{% endif %}
                {% if backfillState.error ?? '' %} &middot; Error: {{ backfillState.error }}{% endif %}
            </p>
        {% endif %}
        <form method="post" action="{{ actionUrl('burrow/settings/save-operations-settings') }}" style="margin-top: 14px;">
            {{ csrfInput() }}
            <label for="burrow-outbox-retention-days"><strong>Outbox retention</strong></label>
            <div style="display: flex; align-items: center; gap: 8px; margin-top: 6px;">
                <input id="burrow-outbox-retention-days" class="text" type="number" name="outboxRetentionDays" min="0" max="365" step="1" value="{{ outboxRetentionDays ?? 30 }}" style="width: 90px;">
                <span class="burrow-card-detail">days</span>
                <button class="btn">Save</button>
            </div>
            <p class="burrow-card-detail" style="margin-top: 6px;">
                Sent and failed records older than this window are removed when you save (and the send dedupe index is trimmed to match).
                Use <strong>0</strong> once to remove <em>all</em> sent/failed rows and clear that index; your saved retention days stay unchanged.
            </p>
        </form>
    </div>
{% endblock %}
