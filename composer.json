{
    "name": "useburrow/craft-burrow",
    "version": "5.3.10",
    "description": "Connect your Craft site to Burrow — the orchestration layer for agency operations. Event tracking, system snapshots, and operational visibility for Freeform, Formie, and Commerce.",
    "type": "craft-plugin",
    "keywords": ["craft", "craftcms", "craft-plugin", "burrow", "agency", "operations", "orchestration", "event-tracking", "freeform", "formie", "craft-commerce", "ecommerce", "analytics", "reporting", "monitoring", "dashboard", "visibility", "integration", "sync", "backfill", "observability", "multi-tenant"],
    "license": "proprietary",
    "authors": [
        {
            "name": "Burrow Analytics, LLC",
            "homepage": "https://useburrow.com"
        }
    ],
    "support": {
        "email": "support@useburrow.com",
        "issues": "https://github.com/useburrow/craft-burrow/issues",
        "source": "https://github.com/useburrow/craft-burrow",
        "docs": "https://github.com/useburrow/craft-burrow/blob/main/README.md"
    },
    "require": {
        "php": "^8.2",
        "craftcms/cms": "^5.0",
        "useburrow/sdk-php": "^0.9.2"
    },
    "autoload": {
        "psr-4": {
            "burrow\\Burrow\\": "src/"
        }
    },
    "extra": {
        "handle": "burrow",
        "name": "Burrow",
        "description": "Connect your Craft site to Burrow — the orchestration layer for agency operations. Event tracking, system snapshots, and operational visibility for Freeform, Formie, and Commerce.",
        "documentationUrl": "https://github.com/useburrow/craft-burrow/blob/main/README.md",
        "developer": "Burrow Analytics, LLC",
        "developerUrl": "https://useburrow.com",
        "class": "burrow\\Burrow\\Plugin"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true,
            "craftcms/plugin-installer": true
        }
    }
}
