{% extends "_layouts/cp" %}

{% set title = "Backfill Probe"|t('burrow') %}
{% set selectedNavItem = 'burrow' %}
{% set selectedSubnavItem = selectedSubnavItem ?? 'dashboard' %}
{% set crumbs = [
    { label: 'Burrow'|t('burrow'), url: cpUrl('burrow') },
    { label: 'Dashboard'|t('burrow'), url: cpUrl('burrow/dashboard') },
] %}

{% block content %}
    <style>
        /* Wide probe grids (many columns / long IDs): scroll inside CP content, don’t spill past layout. */
        .burrow-probe-table-scroll {
            overflow-x: auto;
            max-width: 100%;
            margin-bottom: 14px;
            -webkit-overflow-scrolling: touch;
        }
        .burrow-probe-table-scroll table.data {
            margin-bottom: 0;
        }
    </style>
    <h2>Backfill Probe</h2>
    <p class="light">This is a diagnostics view to verify native query visibility before event submission.</p>

    <form method="get" action="{{ cpUrl('burrow/backfill-probe') }}" style="margin: 10px 0 16px; display:flex; gap:8px; align-items:center;">
        <div class="select">
            <select name="windowPreset">
                {% for key, label in presetOptions %}
                    <option value="{{ key }}" {{ key == windowPreset ? 'selected' : '' }}>{{ label }}</option>
                {% endfor %}
            </select>
        </div>
        <button class="btn">Refresh Probe</button>
        <a class="btn" href="{{ cpUrl('burrow/dashboard') }}#data-backfill">Back to Dashboard</a>
    </form>

    <table class="data fullwidth" style="max-width: 900px; margin-bottom: 16px;">
        <tbody>
        <tr><th>Window start</th><td><code>{{ probe.windowStart }}</code></td></tr>
        <tr><th>Window end</th><td><code>{{ probe.windowEnd }}</code></td></tr>
        <tr><th>Project ID</th><td><code>{{ probe.projectId ?: '-' }}</code></td></tr>
        <tr><th>Forms source ID</th><td><code>{{ probe.sourceIds.forms ?: '-' }}</code></td></tr>
        <tr><th>Ecommerce source ID</th><td><code>{{ probe.sourceIds.ecommerce ?: '-' }}</code></td></tr>
        <tr><th>System source ID</th><td><code>{{ probe.sourceIds.system ?: '-' }}</code></td></tr>
        <tr><th>Available sources</th><td>{{ probe.availableSources|join(', ') ?: 'none' }}</td></tr>
        <tr><th>Built form events</th><td>{{ probe.eventCounts.forms ?? 0 }}</td></tr>
        <tr><th>Built ecommerce events</th><td>{{ probe.eventCounts.ecommerce ?? 0 }}</td></tr>
        </tbody>
    </table>

    {% for adapterId, section in probe.formProbes ?? {} %}
        {% set adapterLabel = formAdapterLabels[adapterId] ?? adapterId %}
        <h3>{{ adapterLabel }} submissions</h3>
        <p>
            <strong>Available:</strong> {{ section.available ? 'yes' : 'no' }},
            <strong>Scanned:</strong> {{ section.scanned ?? 0 }},
            <strong>In window:</strong> {{ section.inWindow ?? 0 }}
            {% if section.error ?? '' %}
                , <strong>Error:</strong> {{ section.error }}
            {% endif %}
        </p>
        {% if section.samples is not empty %}
            <h4 style="margin: 10px 0 6px;">Sample submissions</h4>
            <div class="burrow-probe-table-scroll" style="max-width: 720px;">
            <table class="data fullwidth">
                <thead><tr><th>ID</th><th>Form ID</th><th>Timestamp</th></tr></thead>
                <tbody>
                {% for sample in section.samples %}
                    <tr>
                        <td>{{ sample.id }}</td>
                        <td>{{ sample.formId }}</td>
                        <td>{{ sample.timestamp }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
            </div>
        {% endif %}
    {% endfor %}

    {% set commerceSection = probe.commerce ?? {} %}
    <h3>Commerce orders</h3>
    <p>
        <strong>Available:</strong> {{ commerceSection.available ? 'yes' : 'no' }},
        <strong>Scanned:</strong> {{ commerceSection.scanned ?? 0 }},
        <strong>In window:</strong> {{ commerceSection.inWindow ?? 0 }}
        , <strong>Placed signal:</strong> {{ commerceSection.placedEligible ?? 0 }}
        , <strong>Status signal present:</strong> {{ commerceSection.statusSignalPresent ?? 0 }}
        , <strong>Backfill eligible:</strong> {{ commerceSection.backfillEligible ?? 0 }}
        {% if commerceSection.error ?? '' %}
            , <strong>Error:</strong> {{ commerceSection.error }}
        {% endif %}
    </p>

    {% if (commerceSection.statusBreakdown ?? []) is not empty %}
        <h4 style="margin: 10px 0 6px;">Orders by status (in window)</h4>
        <div class="burrow-probe-table-scroll" style="max-width: 600px;">
        <table class="data fullwidth">
            <thead>
                <tr><th>Status handle</th><th style="text-align:right">Orders</th><th style="text-align:right">Revenue</th></tr>
            </thead>
            <tbody>
            {% for handle, count in commerceSection.statusBreakdown %}
                <tr>
                    <td><code>{{ handle }}</code></td>
                    <td style="text-align:right">{{ count }}</td>
                    <td style="text-align:right">{{ (commerceSection.revenueByStatus[handle] ?? 0)|number_format(2) }}</td>
                </tr>
            {% endfor %}
            <tr style="font-weight:700; border-top:2px solid #ccc;">
                <td>Total</td>
                <td style="text-align:right">{{ commerceSection.inWindow ?? 0 }}</td>
                <td style="text-align:right">{{ (commerceSection.totalRevenue ?? 0)|number_format(2) }}</td>
            </tr>
            </tbody>
        </table>
        </div>
    {% endif %}

    {% set commerceSamples = commerceSection.samples ?? [] %}
    {% if commerceSamples is empty %}
        <p class="light">No commerce sample records.</p>
    {% else %}
        <div class="burrow-probe-table-scroll">
        <table class="data fullwidth">
            <thead>
            <tr>
                {% for column, value in commerceSamples[0] %}
                    <th>{{ column }}</th>
                {% endfor %}
            </tr>
            </thead>
            <tbody>
            {% for sample in commerceSamples %}
                <tr>
                    {% for column, value in sample %}
                        <td>{{ value is same as(null) ? '-' : value }}</td>
                    {% endfor %}
                </tr>
            {% endfor %}
            </tbody>
        </table>
        </div>
    {% endif %}
{% endblock %}
