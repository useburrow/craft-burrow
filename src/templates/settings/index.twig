{% extends "_layouts/cp" %}
{% import "_includes/forms" as forms %}

{% set title = relinkMode ? "Re-link Project"|t('burrow') : "Setup"|t('burrow') %}
{% set selectedNavItem = 'burrow' %}
{% set selectedSubnavItem = selectedSubnavItem ?? 'setup' %}
{% set fullPageForm = false %}
{% set crumbs = [
    { label: 'Burrow'|t('burrow'), url: cpUrl('burrow') },
] %}

{% set stepTitles = {
    connection: 'Establish connection',
    project: 'Choose client (Project)',
    integrations: 'Integrations',
    freeform: 'Freeform setup',
    formie: 'Formie setup',
    commerce: 'Craft Commerce setup',
    review: 'Review',
    finish: 'Finish'
} %}

{% block sidebar %}
    <nav>
        <ul>
            {% for wizardStep, wizardLabel in wizardSteps %}
                {% set isFutureStep = not (relinkMode ?? false) and loop.index0 > currentStepIndex %}
                <li data-step="{{ wizardStep }}" class="{{ isFutureStep ? 'disabled' : '' }}">
                    {% if isFutureStep %}
                        <span class="disabled-link">
                            <span class="burrow-step-num">{{ loop.index }}.</span>{{ wizardLabel }}
                        </span>
                    {% else %}
                        <a href="{{ cpUrl('burrow/setup', relinkMode ? { step: wizardStep, relink: '1' } : { step: wizardStep }) }}" class="{{ wizardStep == step ? 'sel' : '' }}">
                            <span class="burrow-step-num">{{ loop.index }}.</span>{{ wizardLabel }}
                        </a>
                    {% endif %}
                </li>
            {% endfor %}
        </ul>
    </nav>
{% endblock %}

{% block content %}
    <style>
        .burrow-step-num { color: #8f98a3; margin-right: 6px; }
        .burrow-card { padding: 20px; border: 1px solid #e3e5e8; border-radius: 6px; background: #fff; }
        .burrow-grid { display: grid; grid-template-columns: repeat(2, minmax(280px, 1fr)); gap: 16px; }
        .burrow-muted { color: #667085; }
        .burrow-form-list { max-height: 260px; overflow: auto; border: 1px solid #e3e5e8; border-radius: 4px; padding: 8px 12px; }
        .burrow-form-list label { display: block; margin: 6px 0; }
        #sidebar nav ul li.disabled .disabled-link { display: block; padding: 7px 14px; color: #a4acb6; cursor: not-allowed; }
        .burrow-form-integration-block { margin: 0 0 24px 0; padding-top: 8px; border-top: 1px solid #e5e8ec; }
        .burrow-form-integration-block:first-of-type { border-top: 0; padding-top: 0; }
        .burrow-form-integration-block h3 { font-size: 18px; line-height: 1.3; margin: 0 0 10px 0; font-weight: 700; }
        .burrow-field-mapping-table-wrap { margin-top: 8px; }
        .burrow-field-mapping-table-wrap tr.is-disabled td { opacity: 0.5; }
        .burrow-review-table { margin-top: 8px; }
        .burrow-review-actions { margin-top: 10px; display: flex; align-items: center; gap: 10px; }
        .burrow-setup-icon { display: inline-flex; align-items: center; gap: 6px; margin-right: 10px; margin-bottom: 4px; }
        .burrow-setup-icon .burrow-icon-dot { width: 16px; height: 16px; border-radius: 50%; background: #0d66d0; color: #fff; display: inline-flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 700; }
        .burrow-setup-icon .burrow-menu-glyph { width: 16px; height: 16px; object-fit: contain; }
        .burrow-project-select { max-width: 520px; margin-top: 10px; }
        .burrow-project-select .custom-select { width: 100%; }
        .burrow-project-select .menubtn { width: 100%; justify-content: space-between; }
        .burrow-project-detail { margin-top: 8px; font-size: 12px; color: #667085; }
        .burrow-project-detail code { font-size: 11px; }
        .burrow-integration-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; margin-top: 12px; }
        .burrow-integration-card { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; transition: border-color .15s ease, box-shadow .15s ease, background .15s ease; }
        .burrow-integration-card:hover { border-color: #b8c2cf; box-shadow: 0 1px 2px rgba(16, 24, 40, 0.08); }
        .burrow-integration-card.is-selected { border-color: #0d66d0; background: #f4f8ff; box-shadow: 0 0 0 1px rgba(13, 102, 208, 0.15); }
        .burrow-integration-card.is-disabled { opacity: 0.6; background: #f7f8fa; }
        .burrow-integration-card-label { display: grid; grid-template-columns: 28px 1fr; gap: 10px; padding: 12px; cursor: pointer; }
        .burrow-integration-check { width: 16px; height: 16px; margin-top: 3px; accent-color: #0d66d0; }
        .burrow-integration-icon-wrap { width: 20px; height: 20px; border-radius: 4px; background: #eef2f6; display: inline-flex; align-items: center; justify-content: center; margin-right: 8px; vertical-align: middle; }
        .burrow-integration-icon-wrap img { width: 16px; height: 16px; object-fit: contain; }
        .burrow-integration-fallback { font-size: 11px; font-weight: 700; color: #475467; }
        .burrow-integration-title { font-weight: 700; color: #111927; }
        .burrow-integration-meta { margin-top: 3px; font-size: 12px; color: #667085; }
        .burrow-integration-description { margin-top: 6px; font-size: 12px; color: #4b5565; }
        .burrow-integration-status { display: inline-block; margin-top: 6px; font-size: 11px; color: #475467; background: #eef2f6; border-radius: 999px; padding: 2px 8px; }
        .burrow-commerce-panel { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; padding: 14px; margin-top: 10px; }
        .burrow-commerce-header { display: flex; align-items: center; gap: 10px; margin-bottom: 8px; }
        .burrow-commerce-icon { width: 20px; height: 20px; object-fit: contain; }
        .burrow-commerce-mode-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 10px; margin-top: 10px; }
        .burrow-commerce-mode-card { border: 1px solid #d9dde3; border-radius: 8px; background: #fff; }
        .burrow-commerce-mode-card label { display: block; padding: 12px; cursor: pointer; }
        .burrow-commerce-mode-card.is-selected { border-color: #0d66d0; background: #f4f8ff; }
        .burrow-commerce-mode-card .label { font-weight: 700; display: inline-block; margin-bottom: 2px; }
        .burrow-commerce-mode-card .hint { color: #667085; font-size: 12px; }
        .burrow-commerce-funnel { margin-top: 12px; padding: 10px 12px; border-radius: 6px; background: #f7f8fa; border: 1px solid #e3e5e8; }
        .burrow-commerce-funnel.is-disabled { opacity: 0.55; }
        .burrow-commerce-event-list { margin: 8px 0 0 18px; }
        .burrow-commerce-event-list li { margin: 2px 0; }
        .burrow-commerce-status-map { margin-top: 14px; padding: 12px; border-radius: 6px; background: #f7f8fa; border: 1px solid #e3e5e8; }
        .burrow-commerce-status-map.is-disabled { opacity: 0.55; }
        .burrow-status-map-group { margin-bottom: 12px; }
        .burrow-status-map-group:last-child { margin-bottom: 0; }
        .burrow-status-map-label { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
        .burrow-status-map-label code { font-size: 11px; }
        .burrow-status-map-hint { font-size: 12px; margin: 2px 0 6px; }
        .burrow-status-map-checkboxes { display: flex; flex-wrap: wrap; gap: 6px 14px; }
        .burrow-status-checkbox { display: inline-flex; align-items: center; gap: 4px; font-size: 13px; cursor: pointer; }
        .burrow-status-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
        .burrow-review-summary { display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); gap: 10px; margin: 12px 0 6px; }
        .burrow-review-kpi { border: 1px solid #e3e5e8; border-radius: 8px; background: #fff; padding: 10px 12px; }
        .burrow-review-kpi .label { display: block; font-size: 12px; color: #667085; }
        .burrow-review-kpi .value { display: block; margin-top: 2px; font-size: 20px; font-weight: 700; color: #111927; }
        .burrow-review-panel { border: 1px solid #e3e5e8; border-radius: 8px; background: #fff; padding: 12px; margin-top: 12px; }
        .burrow-review-table { margin-top: 8px; }
        .burrow-status-chip { display: inline-flex; align-items: center; border-radius: 999px; padding: 2px 8px; font-size: 11px; font-weight: 600; border: 1px solid transparent; }
        .burrow-status-chip-ready { background: #ecfdf5; color: #047857; border-color: #86efac; }
        .burrow-status-chip-attention { background: #fff7ed; color: #9a3412; border-color: #fdba74; }
        .burrow-status-chip-off { background: #f3f4f6; color: #374151; border-color: #d1d5db; }
    </style>

    <div class="burrow-card">
        {% if not sdkAvailable %}
            <p class="warning with-icon">
                Burrow PHP SDK is not available. Install `useburrow/sdk-php` before onboarding.
            </p>
        {% endif %}

        <h2>{{ stepTitles[step] ?? 'Setup' }}</h2>

        {% if step == 'connection' %}
            <p class="burrow-muted">
                {% if relinkMode %}
                    {{ 'Enter your Burrow account credentials to discover projects and request a new ingestion key.'|t('burrow') }}
                {% else %}
                    {{ 'Connect this Craft site to Burrow and discover available projects.'|t('burrow') }}
                {% endif %}
            </p>

            <form method="post" action="{{ actionUrl('burrow/settings/save-connection') }}">
                {{ csrfInput() }}
                {% if relinkMode %}
                    {{ hiddenInput('relink', '1') }}
                {% endif %}
                {{ forms.textField({
                    label: 'Base URL',
                    name: 'baseUrl',
                    value: settings.baseUrl,
                    required: true
                }) }}
                {{ forms.passwordField({
                    label: 'API Key',
                    name: 'apiKey',
                    value: settings.apiKey,
                    required: true
                }) }}
                <button class="btn submit">Connect & Discover</button>
                {% if relinkMode %}
                    <a class="btn" href="{{ cpUrl('burrow/settings', { section: 'connection' }) }}">{{ 'Cancel'|t('burrow') }}</a>
                {% endif %}
            </form>

        {% elseif step == 'project' %}
            <p class="burrow-muted">
                {% if relinkMode %}
                    {{ 'Confirm the Burrow project for this site. Click Re-link Project to issue a new ingestion key (even if you keep the same project).'|t('burrow') }}
                {% else %}
                    {{ 'Select the Burrow project this Craft site should sync with.'|t('burrow') }}
                {% endif %}
            </p>

            {% if projects is empty %}
                <p>No discovered projects yet. Run Step 1 first.</p>
            {% else %}
                {% set selectedProjectId = state.projectId ?? '' %}
                {% set selectedProjectValue = '' %}
                {% set projectOptions = [] %}
                {% for project in projects %}
                    {% set projectId = project.projectId ?? '' %}
                    {% set projectValue = project|json_encode %}
                    {% set projectLabel = (project.projectName ?: project.projectId) ~ ' — ' ~ (project.clientName ?: project.clientId) %}
                    {% set projectOptions = projectOptions|merge([{
                        label: projectLabel,
                        value: projectValue,
                    }]) %}
                    {% if projectId == selectedProjectId %}
                        {% set selectedProjectValue = projectValue %}
                    {% endif %}
                {% endfor %}
                <form method="post" action="{{ actionUrl('burrow/settings/select-project') }}">
                    {{ csrfInput() }}
                    {% if relinkMode %}
                        {{ hiddenInput('relink', '1') }}
                    {% endif %}
                    <div class="burrow-project-select">
                        {{ forms.customSelectField({
                            label: 'Project'|t('burrow'),
                            id: 'burrowProjectSelection',
                            name: 'projectSelection',
                            options: projectOptions,
                            value: selectedProjectValue,
                            defaultButtonLabel: 'Select a project…'|t('burrow'),
                        }) }}
                    </div>
                    <p class="burrow-project-detail" hidden></p>
                    <div style="margin-top: 15px;">
                        <button class="btn submit">{{ relinkMode ? 'Re-link Project'|t('burrow') : 'Link Project'|t('burrow') }}</button>
                        {% if relinkMode %}
                            <a class="btn" href="{{ cpUrl('burrow/settings', { section: 'connection' }) }}">{{ 'Cancel'|t('burrow') }}</a>
                        {% endif %}
                    </div>
                </form>
                {% js %}
                    (() => {
                        const $container = $('#{{ 'burrowProjectSelection'|namespaceInputId }}');
                        const $input = $('#{{ 'burrowProjectSelection-input'|namespaceInputId }}');
                        const $detail = $container.closest('form').find('.burrow-project-detail');
                        if (!$container.length || !$input.length || !$detail.length) {
                            return;
                        }
                        const syncDetail = () => {
                            const value = $input.val();
                            if (!value) {
                                $detail.prop('hidden', true).text('');
                                return;
                            }
                            let parsed;
                            try {
                                parsed = JSON.parse(value);
                            } catch (error) {
                                $detail.prop('hidden', true).text('');
                                return;
                            }
                            const projectId = parsed.projectId || '';
                            const clientName = parsed.clientName || parsed.clientId || '';
                            if (!projectId) {
                                $detail.prop('hidden', true).text('');
                                return;
                            }
                            $detail.prop('hidden', false).html(
                                'Client: <strong>' + clientName + '</strong> · Project ID: <code>' + projectId + '</code>'
                            );
                        };
                        $container.on('change', syncDetail);
                        syncDetail();
                        $container.closest('form').on('submit', (event) => {
                            if ($input.val()) {
                                return;
                            }
                            event.preventDefault();
                            Craft.cp.displayError('{{ 'Please choose a project.'|t('burrow')|e('js') }}');
                            $container.find('.menubtn').trigger('focus');
                        });
                    })();
                {% endjs %}
            {% endif %}

        {% elseif step == 'integrations' %}
            {% include 'burrow/settings/_integrations-picker' with { settingsMode: false } %}

        {% elseif step in formIntegrationIds %}
            {% set adapterView = integrationStepData.formAdapterViewData[step] ?? null %}
            {% if adapterView %}
                {% include 'burrow/settings/_form-config' with {
                    settingsMode: false,
                    formAdapterId: adapterView.id,
                    formAdapterLabel: adapterView.label,
                    formAdapterDefaultPrefix: adapterView.defaultPrefix,
                    formAdapterData: adapterView,
                } %}
            {% endif %}

        {% elseif step == 'commerce' %}
            {% include 'burrow/settings/_commerce-config' with { settingsMode: false } %}

        {% elseif step == 'review' %}
            {% set contractCount = contractRows|length %}
            {% set integrationCount = integrationReadinessRows|length %}
            {% set readinessReadyCount = 0 %}
            {% set mappedFieldTotal = 0 %}
            {% for row in integrationReadinessRows %}
                {% set normalizedStatus = (row.status ?? '')|lower %}
                {% if 'ready' in normalizedStatus %}
                    {% set readinessReadyCount = readinessReadyCount + 1 %}
                {% endif %}
            {% endfor %}
            {% for row in contractRows %}
                {% set mappedFieldTotal = mappedFieldTotal + (row.mappingCount ?? 0) %}
            {% endfor %}
            <p>Review exactly what will be sent to Burrow when contracts are synced.</p>
            <div class="burrow-review-summary">
                <div class="burrow-review-kpi">
                    <span class="label">Integrations</span>
                    <span class="value">{{ integrationCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Ready</span>
                    <span class="value">{{ readinessReadyCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Contracts to sync</span>
                    <span class="value">{{ contractCount }}</span>
                </div>
                <div class="burrow-review-kpi">
                    <span class="label">Mapped fields</span>
                    <span class="value">{{ mappedFieldTotal }}</span>
                </div>
            </div>

            <div class="burrow-review-panel">
                <h3>Integration Readiness</h3>
                <table class="data fullwidth burrow-review-table">
                    <thead>
                    <tr>
                        <th>Integration</th>
                        <th>Status</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if integrationReadinessRows is empty %}
                        <tr><td colspan="2">No integrations selected.</td></tr>
                    {% else %}
                        {% for row in integrationReadinessRows %}
                            {% set normalizedStatus = (row.status ?? '')|lower %}
                            {% set chipClass = 'burrow-status-chip-attention' %}
                            {% if 'ready' in normalizedStatus %}
                                {% set chipClass = 'burrow-status-chip-ready' %}
                            {% elseif 'off' in normalizedStatus %}
                                {% set chipClass = 'burrow-status-chip-off' %}
                            {% endif %}
                            <tr>
                                <td>{{ row.name }}</td>
                                <td><span class="burrow-status-chip {{ chipClass }}">{{ row.status }}</span></td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="burrow-review-panel">
                <h3>Contracts To Sync</h3>
                <table class="data fullwidth burrow-review-table">
                    <thead>
                    <tr>
                        <th>Provider</th>
                        <th>Form</th>
                        <th>Form ID</th>
                        <th>Mode</th>
                        <th>Mapped fields</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% if contractRows is empty %}
                        <tr><td colspan="5">No enabled contracts yet. Return to provider setup and enable at least one form.</td></tr>
                    {% else %}
                        {% for row in contractRows %}
                            <tr>
                                <td>{{ row.provider }}</td>
                                <td>{{ row.formName ?: '-' }}</td>
                                <td><code>{{ row.externalFormId ?: '-' }}</code></td>
                                <td>{{ row.mode }}</td>
                                <td>{{ row.mappingCount }}</td>
                            </tr>
                        {% endfor %}
                    {% endif %}
                    </tbody>
                </table>
            </div>

            <div class="burrow-review-actions">
                <form method="post" action="{{ actionUrl('burrow/settings/sync-contracts') }}">
                    {{ csrfInput() }}
                    <button class="btn submit">Sync Contracts to Burrow</button>
                </form>
                {% if contractSyncMeta.syncedAt is defined and contractSyncMeta.syncedAt %}
                    <span class="burrow-muted">
                        Last sync: {{ contractSyncMeta.syncedAt }}
                        {% if contractSyncMeta.version is defined and contractSyncMeta.version %}
                            (version: {{ contractSyncMeta.version }})
                        {% endif %}
                    </span>
                {% endif %}
            </div>

        {% elseif step == 'finish' %}
            <table class="data fullwidth" style="max-width:960px;">
                <tbody>
                <tr>
                    <th>Connected Project</th>
                    <td>
                        <code>{{ state.projectId ?: '-' }}</code>
                        {% if projectUrl %}
                            &nbsp;<a href="{{ projectUrl }}" target="_blank" rel="noopener noreferrer">View in Burrow &#8594;</a>
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Base URL</th>
                    <td><code>{{ settings.baseUrl }}</code></td>
                </tr>
                <tr>
                    <th>Integrations</th>
                    <td>
                        {% if integrationSummaryRows is empty %}
                            <span class="burrow-muted">None selected</span>
                        {% else %}
                            {% for row in integrationSummaryRows %}
                                <span class="burrow-setup-icon">
                                    {% if row.iconDataUri %}
                                        <img class="burrow-menu-glyph" src="{{ row.iconDataUri }}" alt="" aria-hidden="true">
                                    {% else %}
                                        <span class="burrow-icon-dot">{{ (row.label|slice(0, 1))|upper }}</span>
                                    {% endif %}
                                    <strong>{{ row.label }}</strong>
                                    {% if row.detail %}
                                        <span class="burrow-muted">{{ row.detail }}</span>
                                    {% endif %}
                                </span>
                            {% endfor %}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <th>Contracts Synced</th>
                    <td>{{ contractSyncMeta.syncedAt ?? 'Not yet synced' }}</td>
                </tr>
                </tbody>
            </table>

            <h2 style="margin-top:24px;">Active Contracts</h2>
            <table class="data fullwidth" style="max-width:900px;">
                <thead>
                <tr>
                    <th>Provider</th>
                    <th>Form</th>
                    <th>Form ID</th>
                    <th>Mode</th>
                    <th>Mapped Fields</th>
                </tr>
                </thead>
                <tbody>
                {% if contractRows is empty %}
                    <tr><td colspan="5">No active contracts.</td></tr>
                {% else %}
                    {% for row in contractRows %}
                        <tr>
                            <td>{{ row.provider }}</td>
                            <td>{{ row.formName ?: '-' }}</td>
                            <td>{{ row.externalFormId ?: '-' }}</td>
                            <td>{{ row.mode }}</td>
                            <td>{{ row.mappingCount }}</td>
                        </tr>
                    {% endfor %}
                {% endif %}
                </tbody>
            </table>

            <h2 style="margin-top:24px;">Craft Commerce</h2>
            {% set commerceConfig = state.integrationSettings.commerce ?? {} %}
            {% if 'commerce' in state.selectedIntegrations and (commerceConfig.mode ?? 'track') == 'track' %}
                <p>Tracking <code>ecommerce.order.placed</code> and <code>ecommerce.item.purchased</code> events for all Craft Commerce orders.</p>
            {% else %}
                <p class="burrow-muted">Commerce tracking is currently off.</p>
            {% endif %}

            <h2 style="margin-top:24px;">Data Backfill</h2>
            {% set backfillMeta = state.integrationSettings.backfill ?? {} %}
            {% set backfillStatus = backfillMeta.status ?? '' %}
            <p class="burrow-muted">
                {% if backfillStatus == 'completed' %}
                    Last backfill completed: {{ backfillMeta.accepted ?? 0 }} accepted, {{ backfillMeta.rejected ?? 0 }} rejected.
                {% elseif backfillStatus == 'failed' %}
                    Last backfill failed. Open Dashboard to review and retry.
                {% elseif backfillStatus == 'running' %}
                    A backfill is running in the queue. Open Dashboard for live counts.
                {% elseif backfillStatus == 'queued' %}
                    A backfill is queued; ensure the queue worker is running.
                {% else %}
                    Next step: run your first backfill in Dashboard to import historical forms and Craft Commerce orders.
                {% endif %}
            </p>
            <p>
                <a class="btn" href="{{ cpUrl('burrow/dashboard') }}#data-backfill">Run Backfill in Dashboard</a>
            </p>
            <p style="margin-top:20px;">
                <a class="btn submit" href="{{ cpUrl('burrow/dashboard') }}">Go to Dashboard</a>
                <a class="btn" href="{{ cpUrl('burrow/setup', { step: 'connection', relink: '1' }) }}" style="margin-left:6px;">Reconfigure</a>
            </p>

        {% else %}
            <p>Burrow bridge is configured.</p>
            <p><strong>Linked project:</strong> {{ state.projectId ?: 'N/A' }}</p>
            <p><strong>Selected integrations:</strong> {{ state.selectedIntegrations|join(', ') ?: 'N/A' }}</p>
            <p><a class="btn" href="{{ cpUrl('burrow/settings', { step: 'review' }) }}">Back to Review</a></p>
        {% endif %}
    </div>
{% endblock %}
